# PulseFlow — Environment Variables
# Copy to .env.local (never commit the real .env file)
#
# Required
DATABASE_URL=postgresql://user:password@localhost:5432/pulseflow
SESSION_SECRET=your-secret-here-min-32-chars

# Clerk Auth (provisioned automatically by Replit when using setupClerkWhitelabelAuth)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PROXY_URL=           # auto-set in production; leave blank in dev

# WhatsApp Cloud API (optional — app runs in sandbox mode without these)
WHATSAPP_ACCESS_TOKEN=          # permanent system-user token from Meta Business Manager
WHATSAPP_PHONE_NUMBER_ID=       # from WhatsApp Cloud API setup in Meta dashboard

# Vite build (set automatically by Replit workflow; do NOT set in .env)
# PORT=3000
# BASE_PATH=/
