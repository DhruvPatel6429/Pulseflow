# PulseFlow — Environment Variables
# Copy this file to .env (never commit your real .env to version control)
#
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — app will not start without these
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon format shown; any Postgres URL works)
# Required by: lib/db (connection), drizzle-kit push (migrations)
# Neon URL format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Clerk — backend secret key (from clerk.com dashboard → API Keys)
# Required by: api-server (clerkMiddleware, @clerk/express)
CLERK_SECRET_KEY=sk_test_...

# Clerk — publishable key (from clerk.com dashboard → API Keys)
# Required by: api-server (publishableKeyFromHost helper)
CLERK_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED (frontend build / Vite)
# ─────────────────────────────────────────────────────────────────────────────

# Clerk publishable key exposed to the browser via Vite
# Required by: artifacts/pulseflow (Clerk React provider)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — app runs with reduced functionality if absent
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key for AI-powered WhatsApp replies
# If absent, the AI engine falls back to rule-based keyword classification
# (fully functional; no external calls made)
# Required by: artifacts/api-server/src/lib/ai/responder.ts
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# RAZORPAY — billing & subscriptions (Indian market)
# ─────────────────────────────────────────────────────────────────────────────

# Razorpay API key pair (from Razorpay Dashboard → Settings → API Keys)
# Required by: artifacts/api-server/src/routes/billing.ts
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=

# Webhook secret (from Razorpay Dashboard → Webhooks → Secret)
# Required to verify POST /api/webhooks/razorpay signatures
RAZORPAY_WEBHOOK_SECRET=

# Razorpay Plan IDs — create plans in Razorpay Dashboard → Subscriptions → Plans
# Starter: ₹999/month, 1 staff login
# Pro:     ₹2499/month, up to 5 staff logins
RAZORPAY_STARTER_PLAN_ID=plan_...
RAZORPAY_PRO_PLAN_ID=plan_...

# Clerk frontend proxy URL — auto-set in Replit production; leave blank in dev
VITE_CLERK_PROXY_URL=

# WhatsApp Cloud API credentials (Meta Business Manager)
# If absent, all WhatsApp sends are logged only — no real messages sent (sandbox mode)
# Required by: artifacts/api-server/src/lib/whatsapp.ts
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Pino log level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY SECRETS — required in production; optional in development
# ─────────────────────────────────────────────────────────────────────────────

# Secret for POST /api/cron/process-automations.
# Send as:  Authorization: Bearer <value>
# In production: if unset the route returns 403. Generate with: openssl rand -hex 32
CRON_SECRET=

# Enables the demo seed routes (POST /api/seed/demo, DELETE /api/seed/demo).
# Defaults to false. Set SEED_ENABLED=true only in controlled dev/demo environments.
# NEVER enable in production with real customer data — routes wipe and re-seed the DB.
SEED_ENABLED=false

# Secret for POST /api/seed/demo and DELETE /api/seed/demo.
# Required when SEED_ENABLED=true. Send as: Authorization: Bearer <value>
# Generate with: openssl rand -hex 32
SEED_SECRET=

# Maximum number of API requests per IP address per minute (default: 100).
# Applies to all /api routes. Increase if Meta webhook deliveries are throttled.
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT ONLY — set automatically by Replit workflows; do NOT set manually
# ─────────────────────────────────────────────────────────────────────────────

# Port the api-server listens on (managed by artifact workflow; dev=3000, prod=8080)
# PORT=3000

# Base URL path prefix for the frontend (managed by artifact workflow)
# BASE_PATH=/

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION ONLY — injected by Replit at deploy time
# ─────────────────────────────────────────────────────────────────────────────

# NODE_ENV=production
