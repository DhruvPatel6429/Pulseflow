# PulseFlow — Environment Variables
# Copy this file to .env (never commit your real .env to version control)
#
# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — app will not start without these
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon format shown; any Postgres URL works)
# Required by: lib/db (connection), drizzle-kit push (migrations)
# Neon URL format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Clerk — backend secret key (from clerk.com dashboard → API Keys)
# Required by: api-server (clerkMiddleware, @clerk/express)
CLERK_SECRET_KEY=sk_test_...

# Clerk — publishable key (from clerk.com dashboard → API Keys)
# Required by: api-server (publishableKeyFromHost helper)
CLERK_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED (frontend build / Vite)
# ─────────────────────────────────────────────────────────────────────────────

# Clerk publishable key exposed to the browser via Vite
# Required by: artifacts/pulseflow (Clerk React provider)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — app runs with reduced functionality if absent
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key for AI-powered WhatsApp replies
# If absent, the AI engine falls back to rule-based keyword classification
# (fully functional; no external calls made)
# Required by: artifacts/api-server/src/lib/ai/responder.ts
OPENAI_API_KEY=sk-...

# Clerk frontend proxy URL — auto-set in Replit production; leave blank in dev
VITE_CLERK_PROXY_URL=

# WhatsApp Cloud API credentials (Meta Business Manager)
# If absent, all WhatsApp sends are logged only — no real messages sent (sandbox mode)
# Required by: artifacts/api-server/src/lib/whatsapp.ts
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Pino log level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT ONLY — set automatically by Replit workflows; do NOT set manually
# ─────────────────────────────────────────────────────────────────────────────

# Port the api-server listens on (managed by artifact workflow)
# PORT=8080

# Base URL path prefix for the frontend (managed by artifact workflow)
# BASE_PATH=/

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION ONLY — injected by Replit at deploy time
# ─────────────────────────────────────────────────────────────────────────────

# NODE_ENV=production
